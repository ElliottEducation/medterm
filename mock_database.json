{
  "pericarditis": {
    "term": "pericarditis",
    "category": "Cardiovascular",
    "chapter1_structure": {
      "components": [{"part": "peri-", "type": "Prefix", "meaning": "around (在...周围)"}, {"part": "cardi", "type": "Word Root", "meaning": "heart (心脏)"}, {"part": "itis", "type": "Suffix", "meaning": "inflammation (炎症)"}],
      "combining_form": "cardi/o",
      "rule_applied": "The Vowel Drop Rule: 后缀 -itis 以元音 i 开头，省略了连接元音 o。"
    },
    "chapter2_extensions": {
      "pronunciation_rule": "c 在 a 前发 /k/。",
      "plural_form": "pericarditides",
      "plural_rule_explanation": "-itis 变为 -itides (古典拉丁规则)。",
      "mnemonics_eponyms": "围绕心脏的炎症。"
    }
  },
  "otorhinolaryngology": {
    "term": "otorhinolaryngology",
    "category": "ENT",
    "chapter1_structure": {
      "components": [{"part": "ot", "type": "Word Root", "meaning": "ear (耳)"}, {"part": "o", "type": "Combining Vowel", "meaning": "连接元音"}, {"part": "rhin", "type": "Word Root", "meaning": "nose (鼻)"}, {"part": "o", "type": "Combining Vowel", "meaning": "连接元音"}, {"part": "laryng", "type": "Word Root", "meaning": "larynx (喉)"}, {"part": "o", "type": "Combining Vowel", "meaning": "连接元音"}, {"part": "logy", "type": "Suffix", "meaning": "study of (学科)"}],
      "combining_form": "ot/o, rhin/o, laryng/o",
      "rule_applied": "多词根保留法则：连接元音 o 全部保留，因为后续成分皆以辅音开头。"
    },
    "chapter2_extensions": {
      "pronunciation_rule": "rh 组合中 h 不发音。",
      "plural_form": "otorhinolaryngologies",
      "plural_rule_explanation": "y 变为 i 加 -es。",
      "mnemonics_eponyms": "耳-鼻-喉科学 (ENT)。"
    }
  },
